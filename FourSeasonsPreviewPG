/* ---------- Render menu from data ---------- */

function renderMenu() {

  const root = document.getElementById("menuRoot");

  const idx = document.getElementById("menuIndex");

  MENU.forEach((cat, ci) => {

    const a = document.createElement("a");

    a.href = "#m-" + cat.id;

    a.textContent = cat.title + (cat.when ? " · " + cat.when : "");

    idx.appendChild(a);



    const sec = document.createElement("div");

    sec.className = "menu-sec"; sec.id = "m-" + cat.id;

    sec.innerHTML = '<h3><span class="sec-num">' + cat.num + '</span>' + cat.title +

      (cat.when ? ' <span class="sec-when">' + cat.when + '</span>' : '') + '</h3>' +

      (cat.note ? '<p class="sec-note">' + cat.note + '</p>' : '');

    cat.items.forEach((it, ii) => {

      it._cat = cat.title; it._id = cat.id + "-" + ii;

      const row = document.createElement("div");

      row.className = "mi";

      row.innerHTML =

        '<span class="nm">' + it.n + (it.sp ? ' <span class="sp">🌶</span>' : '') +

        (it.d ? '<span class="d">' + it.d + '</span>' : '') + '</span>' +

        '<span class="dots"></span><span class="pr">' + priceLabel(it) + '</span>';

      if (ORDERING_ENABLED) {

        const btn = document.createElement("button");

        btn.className = "add-btn"; btn.textContent = "Add"; btn.setAttribute("aria-label", "Add " + it.n + " to order");

        btn.onclick = () => addFlow(ci, ii);

        row.appendChild(btn);

      }

      sec.appendChild(row);

    });

    root.appendChild(sec);

  });

  const foot = document.createElement("div");

  foot.className = "btn-row"; foot.style.marginTop = "40px";

  foot.innerHTML = ORDERING_ENABLED

    ? '<button class="btn btn-solid" onclick="openCart()">View your order</button>' +

      '<a class="btn" href="tel:+15414796532">Call (541) 479-6532</a>'

    : '<a class="btn btn-solid" href="tel:+15414796532">Call (541) 479-6532 to order</a>' +

      '<a class="btn" href="https://order.online/store/-37535244/?pickup=true&hideModal=true" target="_blank" rel="noopener">Order online (DoorDash)</a>';

  root.appendChild(foot);

}



