<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Four Seasons Restaurant — Chinese-American Kitchen, Grants Pass, OR</title>

<meta name="description" content="Four Seasons Restaurant, 122 SE K St, Grants Pass. Chinese-American food cooked to order, no MSG. Call (541) 479-6532 or order online for pickup. Tue–Sat, noon–9.">

<link rel="preconnect" href="https://fonts.googleapis.com">

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Libre+Franklin:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

  :root {

    --paper: #f4efe3;

    --paper-deep: #ebe4d2;

    --ink: #181410;

    --ink-soft: #56503f;

    --cinnabar: #b0341b;

    --lacquer: #14352c;

    --line: #d9d0b9;

    --line-dark: #b9ad8f;

    --serif: 'Fraunces', Georgia, serif;

    --sans: 'Libre Franklin', 'Helvetica Neue', Arial, sans-serif;

  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {

    font-family: var(--sans);

    font-size: 17px;

    line-height: 1.6;

    color: var(--ink);

    background: var(--paper);

    -webkit-font-smoothing: antialiased;

  }

  ::selection { background: var(--cinnabar); color: var(--paper); }



  h1, h2, h3 { font-family: var(--serif); font-weight: 600; line-height: 1.08; letter-spacing: -0.01em; }

  p { margin-bottom: 1em; }

  a { color: var(--ink); text-decoration-thickness: 1px; text-underline-offset: 3px; }

  a:hover { color: var(--cinnabar); }

  img { display: block; max-width: 100%; }



  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }



  .kicker {

    font-family: var(--sans); font-size: 11px; font-weight: 700;

    letter-spacing: 0.22em; text-transform: uppercase; color: var(--cinnabar);

    margin-bottom: 18px;

  }

  .kicker.ink { color: var(--ink-soft); }



  .btn {

    display: inline-block; font-family: var(--sans);

    font-size: 15px; font-weight: 600; letter-spacing: 0.02em;

    padding: 15px 26px; min-height: 50px;

    border: 1.5px solid var(--ink); border-radius: 0;

    background: transparent; color: var(--ink);

    text-decoration: none; cursor: pointer;

    transition: background 0.15s, color 0.15s;

  }

  .btn:hover { background: var(--ink); color: var(--paper); }

  .btn-solid { background: var(--ink); color: var(--paper); }

  .btn-solid:hover { background: var(--cinnabar); border-color: var(--cinnabar); color: var(--paper); }

  .btn-cinnabar { background: var(--cinnabar); border-color: var(--cinnabar); color: var(--paper); }

  .btn-cinnabar:hover { background: var(--ink); border-color: var(--ink); color: var(--paper); }

  .btn-light { border-color: var(--paper); color: var(--paper); }

  .btn-light:hover { background: var(--paper); color: var(--lacquer); }

  .btn[disabled] { opacity: 0.45; cursor: not-allowed; }

  .btn[disabled]:hover { background: transparent; color: var(--ink); }

  .btn-row { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; margin: 26px 0 0; }

  .arrow-link {

    font-family: var(--sans); font-size: 15px; font-weight: 600;

    text-decoration: underline; text-decoration-thickness: 1.5px; text-underline-offset: 4px;

    background: none; border: none; cursor: pointer; color: var(--ink);

  }

  .arrow-link:hover { color: var(--cinnabar); }



  .topline {

    background: var(--ink); color: var(--paper);

    font-size: 12.5px; font-weight: 500; letter-spacing: 0.04em;

    padding: 7px 0;

  }

  .topline .wrap { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }

  .topline a { color: var(--paper); }

  .topline .status-open { color: #8fce9f; font-weight: 600; }

  .topline .status-closed { color: #e8a08f; font-weight: 600; }



  header.site { position: sticky; top: 0; z-index: 100; background: var(--paper); border-bottom: 1px solid var(--ink); }

  .masthead { display: flex; align-items: baseline; justify-content: space-between; gap: 18px; padding: 20px 0 14px; flex-wrap: wrap; }

  .wordmark { text-decoration: none; }

  .wordmark .name { font-family: var(--serif); font-size: clamp(1.5rem, 3vw, 1.9rem); font-weight: 600; letter-spacing: -0.01em; color: var(--ink); }

  .wordmark .name em { font-style: italic; font-weight: 500; color: var(--cinnabar); }

  .wordmark .sub { font-size: 11px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-top: 2px; }

  .mast-call { text-align: right; }

  .mast-call .phone { font-family: var(--serif); font-size: 1.25rem; font-weight: 600; text-decoration: none; }

  .mast-call .note { font-size: 11.5px; color: var(--ink-soft); letter-spacing: 0.06em; text-transform: uppercase; }



  nav.pages { border-top: 1px solid var(--line-dark); }

  nav.pages ul { list-style: none; display: flex; gap: clamp(14px, 3vw, 34px); overflow-x: auto; }

  nav.pages a {

    display: block; padding: 12px 2px; text-decoration: none;

    font-size: 12.5px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;

    color: var(--ink-soft); border-bottom: 3px solid transparent; white-space: nowrap;

  }

  nav.pages a:hover { color: var(--ink); }

  nav.pages a.active { color: var(--ink); border-bottom-color: var(--cinnabar); }



  .page { display: none; }

  .page.active { display: block; }

  section { padding: clamp(56px, 9vw, 104px) 0; }

  .rule-top { border-top: 1px solid var(--line-dark); }



  .hero { padding: clamp(48px, 7vw, 88px) 0 clamp(56px, 8vw, 96px); }

  .hero-grid { display: grid; grid-template-columns: minmax(0, 7fr) minmax(0, 5fr); gap: clamp(28px, 5vw, 72px); align-items: end; }

  .hero h1 { font-size: clamp(2.6rem, 5.6vw, 4.6rem); font-weight: 560; max-width: 13ch; }

  .hero h1 em { font-style: italic; font-weight: 500; color: var(--cinnabar); }

  .hero .lede { font-size: clamp(1.05rem, 1.6vw, 1.2rem); color: var(--ink-soft); max-width: 44ch; margin-top: 22px; }

  .hero-photo { position: relative; }

  .hero-photo img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; }

  .hero-photo::after { content: ""; position: absolute; inset: 14px -14px -14px 14px; border: 1.5px solid var(--ink); z-index: -1; }

  .hero-caption { font-size: 12px; color: var(--ink-soft); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 22px; }



  .facts { border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }

  .facts-grid { display: grid; grid-template-columns: repeat(3, 1fr); }

  .fact { padding: 22px 26px 24px; border-left: 1px solid var(--line-dark); }

  .fact:first-child { border-left: none; padding-left: 0; }

  .fact .label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cinnabar); margin-bottom: 6px; }

  .fact .value { font-family: var(--serif); font-size: 1.12rem; font-weight: 500; line-height: 1.35; }

  .fact .value a { text-decoration: none; }

  .fact .value a:hover { text-decoration: underline; }



  .sec-head { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: clamp(30px, 5vw, 54px); flex-wrap: wrap; }

  .sec-head h2 { font-size: clamp(1.9rem, 3.6vw, 2.9rem); font-weight: 560; }

  .sec-head .num { font-family: var(--serif); font-style: italic; color: var(--cinnabar); margin-right: 10px; font-weight: 500; }



  .dish-row {

    display: grid; grid-template-columns: 64px minmax(0, 5fr) minmax(0, 4fr);

    gap: clamp(18px, 3.5vw, 44px); align-items: center;

    padding: clamp(24px, 3.5vw, 36px) 0; border-top: 1px solid var(--line-dark);

  }

  .dish-row:last-of-type { border-bottom: 1px solid var(--line-dark); }

  .dish-row .idx { font-family: var(--serif); font-style: italic; font-size: 1.15rem; color: var(--ink-soft); }

  .dish-row h3 { font-size: clamp(1.35rem, 2.4vw, 1.9rem); font-weight: 560; }

  .dish-row .price { font-family: var(--serif); font-style: italic; font-size: 1.1rem; color: var(--cinnabar); margin-left: 12px; }

  .dish-row .desc { color: var(--ink-soft); font-size: 15.5px; margin: 8px 0 0; max-width: 46ch; }

  .dish-row img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }

  .dish-row:nth-child(even) { grid-template-columns: 64px minmax(0, 4fr) minmax(0, 5fr); }

  .dish-row:nth-child(even) .txt { order: 3; }

  .dish-row:nth-child(even) img { order: 2; }

  .after-dishes { margin-top: 34px; }



  .pull { padding: clamp(64px, 10vw, 120px) 0; }

  .pull blockquote {

    font-family: var(--serif); font-style: italic; font-weight: 500;

    font-size: clamp(1.7rem, 3.8vw, 3rem); line-height: 1.22; max-width: 21ch;

  }

  .pull blockquote::before { content: "“"; color: var(--cinnabar); }

  .pull blockquote::after { content: "”"; color: var(--cinnabar); }

  .pull cite { display: block; font-family: var(--sans); font-style: normal; font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); margin-top: 26px; }



  .band { background: var(--lacquer); color: var(--paper); }

  .band .kicker { color: #c8a45c; }

  .band-grid { display: grid; grid-template-columns: minmax(0, 7fr) minmax(0, 4fr); gap: clamp(28px, 5vw, 80px); align-items: center; }

  .band h2 { font-size: clamp(1.9rem, 3.6vw, 2.9rem); font-weight: 560; color: var(--paper); }

  .band p { color: #cfd8cd; max-width: 52ch; }

  .band .fine { font-size: 13px; color: #9db3a6; }



  .visit-grid { display: grid; grid-template-columns: minmax(0, 5fr) minmax(0, 6fr); gap: clamp(28px, 5vw, 72px); align-items: start; }

  .visit-info .row { padding: 18px 0; border-top: 1px solid var(--line-dark); }

  .visit-info .row:last-child { border-bottom: 1px solid var(--line-dark); }

  .visit-info .label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cinnabar); margin-bottom: 4px; }

  .visit-info .value { font-family: var(--serif); font-size: 1.15rem; font-weight: 500; }

  .map-frame { width: 100%; height: 420px; border: 1.5px solid var(--ink); filter: grayscale(0.35) sepia(0.12); }



  /* ---------- Menu page ---------- */

  .menu-layout { display: grid; grid-template-columns: 220px minmax(0, 1fr); gap: clamp(28px, 4vw, 64px); align-items: start; }

  .menu-index { position: sticky; top: 132px; }

  .menu-index .label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cinnabar); margin-bottom: 12px; }

  .menu-index a {

    display: block; padding: 6px 0; text-decoration: none;

    font-size: 13.5px; font-weight: 600; color: var(--ink-soft);

    border-bottom: 1px solid var(--line);

  }

  .menu-index a:hover { color: var(--cinnabar); }

  .menu-sec { padding: 34px 0 8px; }

  .menu-sec h3 {

    font-size: clamp(1.4rem, 2.2vw, 1.8rem); font-weight: 560;

    padding-bottom: 12px; border-bottom: 1.5px solid var(--ink); margin-bottom: 6px;

  }

  .menu-sec h3 .sec-num { font-style: italic; font-weight: 500; color: var(--cinnabar); font-size: 0.75em; margin-right: 10px; }

  .menu-sec h3 .sec-when { font-family: var(--sans); font-size: 0.5em; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); }

  .menu-sec .sec-note { font-size: 13px; color: var(--ink-soft); font-style: italic; padding: 8px 0 2px; }

  .mi { display: flex; align-items: baseline; gap: 10px; padding: 11px 0; border-bottom: 1px solid var(--line); }

  .mi .nm { font-family: var(--serif); font-weight: 500; font-size: 1.04rem; }

  .mi .nm .d { display: block; font-family: var(--sans); font-size: 13px; color: var(--ink-soft); font-weight: 400; margin-top: 2px; }

  .mi .dots { flex: 1; border-bottom: 1px dotted var(--line-dark); transform: translateY(-4px); min-width: 24px; }

  .mi .pr { font-family: var(--serif); font-weight: 600; font-size: 1rem; white-space: nowrap; }

  .sp { color: var(--cinnabar); font-size: 0.85em; }

  .menu-topnote { font-size: 14px; color: var(--ink-soft); border: 1px solid var(--line-dark); padding: 14px 18px; margin: 26px 0 8px; }

  .menu-topnote strong { color: var(--ink); }



  .add-btn {

    font-family: var(--sans); font-size: 13px; font-weight: 700;

    border: 1.5px solid var(--ink); background: transparent; color: var(--ink);

    min-width: 44px; min-height: 34px; padding: 4px 12px; cursor: pointer;

    letter-spacing: 0.06em; flex-shrink: 0; align-self: center;

    transition: background 0.12s, color 0.12s;

  }

  .add-btn:hover { background: var(--cinnabar); border-color: var(--cinnabar); color: var(--paper); }



  /* ---------- Cart drawer ---------- */

  .cart-fab {

    position: fixed; right: 18px; bottom: 18px; z-index: 300;

    background: var(--ink); color: var(--paper); border: none; cursor: pointer;

    font-family: var(--sans); font-size: 14px; font-weight: 700; letter-spacing: 0.06em;

    padding: 16px 22px; display: none; align-items: center; gap: 10px;

    box-shadow: 4px 4px 0 var(--cinnabar);

  }

  .cart-fab.show { display: flex; }

  .cart-fab:hover { background: var(--cinnabar); box-shadow: 4px 4px 0 var(--ink); }

  .cart-fab .ct { background: var(--paper); color: var(--ink); font-size: 12px; padding: 1px 8px; }



  .scrim { display: none; position: fixed; inset: 0; background: rgba(24,20,16,0.5); z-index: 400; }

  .scrim.show { display: block; }

  .drawer {

    position: fixed; top: 0; right: 0; bottom: 0; width: min(440px, 100vw); z-index: 410;

    background: var(--paper); border-left: 1.5px solid var(--ink);

    transform: translateX(105%); transition: transform 0.22s ease;

    display: flex; flex-direction: column;

  }

  .drawer.show { transform: translateX(0); }

  .drawer-head { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1.5px solid var(--ink); }

  .drawer-head h3 { font-size: 1.4rem; font-weight: 560; }

  .drawer-close { background: none; border: none; font-size: 26px; cursor: pointer; color: var(--ink-soft); line-height: 1; }

  .drawer-close:hover { color: var(--cinnabar); }

  .drawer-body { flex: 1; overflow-y: auto; padding: 10px 24px; }

  .cart-empty { color: var(--ink-soft); font-style: italic; padding: 30px 0; }

  .cline { padding: 14px 0; border-bottom: 1px solid var(--line); }

  .cline-top { display: flex; justify-content: space-between; gap: 12px; align-items: baseline; }

  .cline .nm { font-family: var(--serif); font-weight: 500; font-size: 1.02rem; }

  .cline .amt { font-family: var(--serif); font-weight: 600; white-space: nowrap; }

  .cline .mods { font-size: 12.5px; color: var(--ink-soft); font-style: italic; margin-top: 2px; }

  .cline-ctl { display: flex; align-items: center; gap: 6px; margin-top: 8px; }

  .qbtn { width: 32px; height: 32px; border: 1px solid var(--line-dark); background: transparent; font-size: 16px; font-weight: 700; cursor: pointer; color: var(--ink); }

  .qbtn:hover { border-color: var(--cinnabar); color: var(--cinnabar); }

  .qnum { min-width: 30px; text-align: center; font-weight: 700; font-size: 15px; }

  .cline .rm { background: none; border: none; font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-soft); cursor: pointer; margin-left: auto; text-decoration: underline; text-underline-offset: 3px; }

  .cline .rm:hover { color: var(--cinnabar); }

  .drawer-foot { border-top: 1.5px solid var(--ink); padding: 18px 24px 22px; background: var(--paper-deep); }

  .subtotal-row { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }

  .subtotal-row .lbl { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-soft); }

  .subtotal-row .val { font-family: var(--serif); font-size: 1.6rem; font-weight: 600; }

  .drawer-foot .fine { font-size: 12px; color: var(--ink-soft); margin: 4px 0 12px; }

  .drawer-foot .btn { width: 100%; text-align: center; }



  .pickup-form .form-row { margin-bottom: 14px; }

  .checkout-note { border: 1px dashed var(--line-dark); padding: 12px 14px; font-size: 13px; color: var(--ink-soft); margin: 14px 0; }



  /* ---------- Config modal ---------- */

  .cfg-overlay { display: none; position: fixed; inset: 0; background: rgba(24,20,16,0.5); z-index: 500; align-items: center; justify-content: center; padding: 18px; }

  .cfg-overlay.show { display: flex; }

  .cfg {

    background: var(--paper); border: 1.5px solid var(--ink);

    width: min(460px, 100%); max-height: 86vh; overflow-y: auto; padding: 26px;

  }

  .cfg h3 { font-size: 1.35rem; font-weight: 560; }

  .cfg .base-note { font-size: 13px; color: var(--ink-soft); font-style: italic; margin: 4px 0 14px; }

  .cfg-group { margin: 16px 0; }

  .cfg-group .glabel { font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cinnabar); margin-bottom: 8px; }

  .cfg-opt { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border: 1px solid var(--line-dark); margin-bottom: 6px; cursor: pointer; font-size: 14.5px; }

  .cfg-opt:hover { border-color: var(--ink); }

  .cfg-opt input { width: auto; min-height: 0; accent-color: var(--cinnabar); }

  .cfg-opt .up { margin-left: auto; font-family: var(--serif); font-weight: 600; font-size: 13.5px; color: var(--ink-soft); }

  .cfg-qty { display: flex; align-items: center; gap: 8px; }

  .cfg-note { font-size: 12.5px; color: var(--ink-soft); font-style: italic; margin-top: 6px; }

  .cfg-actions { display: flex; gap: 10px; margin-top: 20px; }

  .cfg-actions .btn { flex: 1; text-align: center; padding: 13px 10px; }

  .pick-status { font-size: 13px; font-weight: 600; margin-top: 6px; }

  .pick-status.ok { color: #1d6b34; }

  .pick-status.bad { color: var(--cinnabar); }



  form.catering { border: 1.5px solid var(--ink); padding: clamp(24px, 4vw, 40px); background: var(--paper); }

  .form-row { margin-bottom: 20px; }

  label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 7px; }

  input, textarea, select {

    width: 100%; padding: 13px 14px; min-height: 48px;

    font-family: var(--sans); font-size: 16px; color: var(--ink);

    background: #fbf8f0; border: 1px solid var(--line-dark); border-radius: 0;

  }

  input:focus, textarea:focus, select:focus { outline: 2px solid var(--cinnabar); outline-offset: -1px; border-color: var(--cinnabar); }



  .quote-stack blockquote {

    font-family: var(--serif); font-style: italic; font-weight: 500;

    font-size: clamp(1.3rem, 2.6vw, 1.9rem); line-height: 1.3;

    padding: clamp(26px, 4vw, 40px) 0; border-top: 1px solid var(--line-dark);

    max-width: 30ch;

  }

  .quote-stack blockquote:nth-child(even) { margin-left: auto; text-align: right; }

  .quote-stack blockquote:last-of-type { border-bottom: 1px solid var(--line-dark); }

  .quote-stack blockquote::before { content: "“"; color: var(--cinnabar); }

  .quote-stack blockquote::after { content: "”"; color: var(--cinnabar); }



  .prose { max-width: 62ch; font-size: clamp(1.02rem, 1.5vw, 1.15rem); color: var(--ink-soft); }

  .prose strong { color: var(--ink); }



  footer.site { background: var(--ink); color: #cfc8b8; padding: clamp(48px, 7vw, 80px) 0 40px; }

  footer.site a { color: var(--paper); }

  footer.site a:hover { color: #e0876f; }

  .foot-grid { display: grid; grid-template-columns: minmax(0, 5fr) minmax(0, 3fr) minmax(0, 3fr); gap: clamp(28px, 5vw, 64px); }

  .foot-name { font-family: var(--serif); font-size: 1.7rem; font-weight: 560; color: var(--paper); }

  .foot-name em { font-style: italic; color: #e0876f; }

  .foot-label { font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #8d8674; margin-bottom: 10px; }

  .foot-grid p { font-size: 15px; margin-bottom: 6px; }

  .foot-phone { font-family: var(--serif); font-size: 1.3rem; }

  .foot-base { border-top: 1px solid #3a352b; margin-top: 44px; padding-top: 20px; font-size: 12.5px; color: #8d8674; display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap; }



  @media (max-width: 880px) {

    .hero-grid, .band-grid, .visit-grid { grid-template-columns: 1fr; }

    .hero-photo { max-width: 520px; }

    .facts-grid { grid-template-columns: 1fr; }

    .fact { border-left: none; border-top: 1px solid var(--line-dark); padding: 16px 0; }

    .fact:first-child { border-top: none; }

    .menu-layout { grid-template-columns: 1fr; }

    .menu-index { position: static; display: flex; flex-wrap: wrap; gap: 8px 16px; border-bottom: 1px solid var(--line-dark); padding-bottom: 16px; }

    .menu-index .label { width: 100%; }

    .menu-index a { border-bottom: none; padding: 2px 0; }

    .dish-row, .dish-row:nth-child(even) { grid-template-columns: 1fr; gap: 14px; }

