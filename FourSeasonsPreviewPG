/* ---------- Cart state ---------- */

let cart = [];

try { cart = JSON.parse(localStorage.getItem("fs_cart") || "[]"); } catch (e) { cart = []; }

let drawerStep = "cart"; // cart | details



function saveCart() { localStorage.setItem("fs_cart", JSON.stringify(cart)); }

function cartCount() { return cart.reduce((s, l) => s + l.qty, 0); }

function cartTotal() { return cart.reduce((s, l) => s + l.unit * l.qty, 0); }



function addLine(item, unit, mods, qty, sel) {

  const key = item._id + "|" + mods.join(";");

  const found = cart.find(l => l.key === key);

  if (found) found.qty += qty;

  else cart.push({ key, id: item._id, name: item.n, cat: item._cat, unit, qty, mods, sel: sel || {}, per: !!item.per, min: item.min || 1 });

  saveCart(); syncFab();

  openCart();

}



/* ---------- Add flow: direct or configure ---------- */

function needsConfig(it) { return !!(it.sp || it.v || it.o || it.ad || it.pick || it.per || it.parts); }



// option choices may be "Label" (free) or ["Label", +delta]

const oc = (c) => Array.isArray(c) ? c : [c, 0];



function addFlow(ci, ii) {

  const it = MENU[ci].items[ii];

  if (!needsConfig(it)) { addLine(it, it.p, [], 1, {}); return; }

  openConfig(it);

}



function openConfig(it) {

  const box = document.getElementById("cfgBox");

  let html = '<h3>' + it.n + (it.sp ? ' <span class="sp">🌶</span>' : '') + '</h3>';

  if (it.d) html += '<p class="base-note">' + it.d + '</p>';



  if (it.v) {

    html += '<div class="cfg-group"><div class="glabel">' + (it.n === "Pad Thai" || it.n === "Lo Mein" ? "Choice" : "Size") + '</div>';

    it.v.forEach((v, i) => {

      html += '<label class="cfg-opt"><input type="radio" name="cfg-v" value="' + i + '"' + (i === 0 ? ' checked' : '') + '> ' + v[0] + '<span class="up">' + fmt(v[1]) + '</span></label>';

    });

    html += '</div>';

  }

  (it.o || []).forEach((g, gi) => {

    html += '<div class="cfg-group"><div class="glabel">' + g.t + '</div>';

    g.c.forEach((c, i) => {

      const ch = oc(c);

      html += '<label class="cfg-opt"><input type="radio" name="cfg-o' + gi + '" value="' + i + '"' + (i === 0 ? ' checked' : '') + '> ' + ch[0] +

        (ch[1] ? '<span class="up">+' + fmt(ch[1]) + '</span>' : '') + '</label>';

    });

    html += '</div>';

  });

  if (it.sp) {

    html += '<div class="cfg-group"><div class="glabel">Spice level</div>';

    SPICE_LEVELS.forEach((s, i) => {

      html += '<label class="cfg-opt"><input type="radio" name="cfg-sp" value="' + i + '"' + (i === 2 ? ' checked' : '') + '> ' + s[0] +

        (s[1] ? '<span class="up">+' + fmt(s[1]) + (it.per ? ' / person' : '') + '</span>' : '') + '</label>';

    });

    html += '</div>';

  }

  if (it.parts) {

    html += '<div class="cfg-group"><div class="glabel">Substitutions — ' + fmt(SUB_COST) + (it.per ? ' per person' : '') + ' each · removals free</div>';

    it.parts.forEach((p, pi) => {

      html += '<div class="cfg-opt" style="cursor:default; gap:12px;"><span style="flex:1; font-size:14px;">' + p + '</span>' +

        '<select name="cfg-sub" data-part="' + pi + '" style="width:auto; min-height:38px; padding:6px 8px; font-size:14px;">' +

        '<option value="k">Keep</option>' +

        SUB_CHOICES.map((s, si) => '<option value="' + si + '">→ ' + s + '</option>').join('') +

        '<option value="r">Remove (free)</option>' +

        '</select></div>';

    });

    html += '</div>';

  }

  (it.ad || []).forEach((a, ai) => {

    html += '<div class="cfg-group"><label class="cfg-opt"><input type="checkbox" name="cfg-ad" value="' + ai + '"> ' + a[0] + '<span class="up">+' + fmt(a[1]) + '</span></label></div>';

  });

  if (it.pick) {

    html += '<div class="cfg-group"><div class="glabel">Pick ' + it.pick.n + ' items</div>';

    CHOICE_PICKS.forEach((c, i) => {

      html += '<label class="cfg-opt"><input type="checkbox" name="cfg-pick" value="' + i + '" onchange="pickChanged(' + it.pick.n + ')"> ' + c[0] + (c[1] ? '<span class="up">+' + fmt(c[1]) + '</span>' : '') + '</label>';

    });

    html += '<div class="pick-status bad" id="pickStatus">0 of ' + it.pick.n + ' selected</div></div>';

  }

  html += '<div class="cfg-group"><div class="glabel">' + (it.per ? "How many people? (min " + (it.min || 2) + ")" : "Quantity") + '</div>' +

    '<div class="cfg-qty"><button class="qbtn" onclick="cfgQty(-1)">−</button><span class="qnum" id="cfgQtyN">' + (it.min || 1) + '</span><button class="qbtn" onclick="cfgQty(1)">+</button></div>' +

    (it.per ? '<div class="cfg-note">Priced per person.</div>' : '') + '</div>';

  html += '<div class="cfg-actions"><button class="btn" onclick="closeConfig()">Cancel</button>' +

    '<button class="btn btn-cinnabar" id="cfgAdd">Add — <span id="cfgTotal"></span></button></div>';



  box.innerHTML = html;

  document.getElementById("cfgOverlay").classList.add("show");

  box.dataset.min = it.min || 1;



  const recalc = () => {

    const qty = parseInt(document.getElementById("cfgQtyN").textContent, 10);

    let unit = it.v ? it.v[parseInt(box.querySelector('input[name="cfg-v"]:checked').value, 10)][1] : it.p;

    (it.o || []).forEach((g, gi) => {

      const el = box.querySelector('input[name="cfg-o' + gi + '"]:checked');

      if (el) unit += oc(g.c[parseInt(el.value, 10)])[1];

    });

    if (it.sp) {

      const spEl = box.querySelector('input[name="cfg-sp"]:checked');

      if (spEl) unit += SPICE_LEVELS[parseInt(spEl.value, 10)][1];

    }

    box.querySelectorAll('input[name="cfg-ad"]:checked').forEach(ch => unit += it.ad[parseInt(ch.value, 10)][1]);

    box.querySelectorAll('input[name="cfg-pick"]:checked').forEach(ch => unit += CHOICE_PICKS[parseInt(ch.value, 10)][1]);

    box.querySelectorAll('select[name="cfg-sub"]').forEach(s => { if (s.value !== "k" && s.value !== "r") unit += SUB_COST; });

    document.getElementById("cfgTotal").textContent = fmt(unit * qty);

    return { unit, qty };

  };

  box.addEventListener("change", recalc);

  box._recalc = recalc;

  recalc();



  document.getElementById("cfgAdd").onclick = () => {

    const { unit, qty } = recalc();

    if (it.pick) {

      const picked = box.querySelectorAll('input[name="cfg-pick"]:checked').length;

      if (picked !== it.pick.n) { document.getElementById("pickStatus").textContent = "Please select exactly " + it.pick.n + " items."; return; }

    }

    const mods = [], selData = {};

    if (it.v) {

      const vi = parseInt(box.querySelector('input[name="cfg-v"]:checked').value, 10);

      selData.v = vi; mods.push(it.v[vi][0]);

    }

    (it.o || []).forEach((g, gi) => {

      const oEl = box.querySelector('input[name="cfg-o' + gi + '"]:checked');

      const oi = parseInt(oEl.value, 10);

      (selData.o = selData.o || []).push(oi);

      mods.push(g.t + ": " + oc(g.c[oi])[0]);

    });

    if (it.sp) {

      const si = parseInt(box.querySelector('input[name="cfg-sp"]:checked').value, 10);

      selData.sp = SPICE_LEVELS[si][0];

      mods.push(SPICE_LEVELS[si][0]);

    }

    if (it.parts) {

      selData.subs = [];

      box.querySelectorAll('select[name="cfg-sub"]').forEach(s => {

        const pi = parseInt(s.getAttribute('data-part'), 10);

        if (s.value === "k") { selData.subs.push("k"); }

        else if (s.value === "r") { selData.subs.push("r"); mods.push("No " + it.parts[pi]); }

        else { const si2 = parseInt(s.value, 10); selData.subs.push(si2); mods.push(it.parts[pi] + " → " + SUB_CHOICES[si2]); }

      });

    }

    box.querySelectorAll('input[name="cfg-ad"]:checked').forEach(ch => {

      const ai = parseInt(ch.value, 10);

      (selData.ad = selData.ad || []).push(ai);

      mods.push(it.ad[ai][0]);

    });

    box.querySelectorAll('input[name="cfg-pick"]:checked').forEach(ch => {

      const pi = parseInt(ch.value, 10);

      (selData.pick = selData.pick || []).push(pi);

      mods.push(CHOICE_PICKS[pi][0]);

    });

    closeConfig();

    addLine(it, unit, mods, qty, selData);

  };

}

function pickChanged(n) {

  const box = document.getElementById("cfgBox");

  const picked = box.querySelectorAll('input[name="cfg-pick"]:checked').length;

  const st = document.getElementById("pickStatus");

  st.textContent = picked + " of " + n + " selected";

  st.className = "pick-status " + (picked === n ? "ok" : "bad");

}

function cfgQty(d) {

  const el = document.getElementById("cfgQtyN");

  const min = parseInt(document.getElementById("cfgBox").dataset.min, 10);

  el.textContent = Math.max(min, parseInt(el.textContent, 10) + d);

  document.getElementById("cfgBox")._recalc();

}

function closeConfig() { document.getElementById("cfgOverlay").classList.remove("show"); }



/* ---------- Drawer ---------- */

function syncFab() {

  const fab = document.getElementById("cartFab");

  document.getElementById("fabCount").textContent = cartCount();

  document.getElementById("fabTotal").textContent = fmt(cartTotal());

  fab.classList.toggle("show", ORDERING_ENABLED && cart.length > 0);

}

function openCart() { drawerStep = "cart"; renderDrawer(); document.getElementById("drawer").classList.add("show"); document.getElementById("scrim").classList.add("show"); }

function closeCart() { document.getElementById("drawer").classList.remove("show"); document.getElementById("scrim").classList.remove("show"); }



function lineQty(i, d) {

  const l = cart[i];

  l.qty += d;

  const min = l.per ? l.min : 1;

  if (l.qty < min) cart.splice(i, 1);

  saveCart(); syncFab(); renderDrawer();

}

function lineRemove(i) { cart.splice(i, 1); saveCart(); syncFab(); renderDrawer(); }



function renderDrawer() {

  const body = document.getElementById("drawerBody");

  const foot = document.getElementById("drawerFoot");

  const title = document.getElementById("drawerTitle");



  if (drawerStep === "details") { renderDetails(); return; }

  if (drawerStep === "pay") { renderPay(); return; }

  if (drawerStep === "done") { renderDone(); return; }

  title.textContent = "Your pickup order";



  if (!cart.length) {

    body.innerHTML = '<p class="cart-empty">Nothing here yet — add dishes from the menu.</p>';

    foot.innerHTML = '<button class="btn" style="width:100%" onclick="closeCart(); showPage(\'menu\')">Browse the menu</button>';

    return;

  }

  body.innerHTML = cart.map((l, i) =>

    '<div class="cline">' +

      '<div class="cline-top"><span class="nm">' + l.name + (l.per ? " · " + l.qty + " people" : "") + '</span><span class="amt">' + fmt(l.unit * l.qty) + '</span></div>' +

      (l.mods.length ? '<div class="mods">' + l.mods.join(" · ") + '</div>' : '') +

      '<div class="cline-ctl">' +

        '<button class="qbtn" onclick="lineQty(' + i + ',-1)">−</button><span class="qnum">' + l.qty + '</span><button class="qbtn" onclick="lineQty(' + i + ',1)">+</button>' +

        '<span style="font-size:12px;color:var(--ink-soft);">' + (l.per ? "people" : "× " + fmt(l.unit)) + '</span>' +

        '<button class="rm" onclick="lineRemove(' + i + ')">Remove</button>' +

      '</div>' +

    '</div>'

  ).join("");

  foot.innerHTML =

    '<div class="subtotal-row"><span class="lbl">Total</span><span class="val">' + fmt(cartTotal()) + '</span></div>' +

    '<p class="fine">Pickup only · No sales tax in Oregon · Pay by card online (setup in progress) or when you pick up.</p>' +

    '<button class="btn btn-cinnabar" onclick="drawerStep=\'details\'; renderDrawer()">Pickup details →</button>';

}



/* ---------- Pickup details ---------- */

function pickupSlots() {

  // Open Tue(2)–Sat(6), noon–9. Online pickup slots every 15 min, first ~25 min out, last 8:45 PM.

  const now = new Date(new Date().toLocaleString("en-US", { timeZone: "America/Los_Angeles" }));

  const slots = [];

  const day = now.getDay();

  const openDays = [2, 3, 4, 5, 6];

  if (openDays.includes(day)) {

    let t = new Date(now.getTime() + 25 * 60000);

    t.setMinutes(Math.ceil(t.getMinutes() / 15) * 15, 0, 0);

    const start = new Date(now); start.setHours(12, 15, 0, 0);

    if (t < start) t = start;

    const end = new Date(now); end.setHours(20, 45, 0, 0);

    if (now.getHours() >= 12 && now < end) slots.push(["ASAP", "ASAP (about 15–20 min)"]);

    while (t <= end) {

      slots.push([t.toTimeString().slice(0, 5), t.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" })]);

      t = new Date(t.getTime() + 15 * 60000);

    }

  }

  return slots;

}



function renderDetails() {

  const body = document.getElementById("drawerBody");

  const foot = document.getElementById("drawerFoot");

  document.getElementById("drawerTitle").textContent = "Pickup details";

  const slots = pickupSlots();

  const slotHtml = slots.length

    ? '<select id="p-time">' + slots.map(s => '<option value="' + s[0] + '">' + s[1] + '</option>').join("") + '</select>'

    : '<p style="font-size:14px;color:var(--cinnabar);font-weight:600;">We\'re closed right now (Tue–Sat, noon–9 PM). You can still build your order and call it in for our next open day.</p>';



  body.innerHTML =

    '<div class="pickup-form" style="padding-top:14px;">' +

      '<div class="form-row"><label for="p-name">Your name</label><input id="p-name" type="text" autocomplete="name" value="' + (pickupInfo.name || '') + '" required></div>' +

      '<div class="form-row"><label for="p-phone">Phone number</label><input id="p-phone" type="tel" autocomplete="tel" value="' + (pickupInfo.phone || '') + '" required></div>' +

      '<div class="form-row"><label for="p-time">Pickup time</label>' + slotHtml + '</div>' +

      '<div class="pick-status bad" id="detailsMsg"></div>' +

    '</div>';

  foot.innerHTML =

    '<div class="subtotal-row"><span class="lbl">Total</span><span class="val">' + fmt(cartTotal()) + '</span></div>' +

    '<p class="fine">No sales tax in Oregon. Card is charged when you place the order.</p>' +

    '<button class="btn btn-cinnabar" style="margin-bottom:10px;" onclick="startPayment()">Continue to payment →</button>' +

    '<button class="btn" onclick="location.href=\'tel:+15414796532\'">Or call it in — (541) 479-6532</button>' +

    '<p class="fine" style="margin-top:10px;"><button class="arrow-link" style="font-size:13px;" onclick="drawerStep=\'cart\'; renderDrawer()">← Back to your order</button></p>';

}



/* ---------- Payment step (Square Web Payments SDK, embedded — no redirect) ---------- */

let pickupInfo = {};

let sqCard = null;



function startPayment() {

  const msg = document.getElementById("detailsMsg");

  const name = (document.getElementById("p-name").value || "").trim();

  const phone = (document.getElementById("p-phone").value || "").trim();

  const timeEl = document.getElementById("p-time");

  if (!name || !phone) { msg.textContent = "Please enter your name and phone number."; return; }

  if (phone.replace(/\D/g, "").length < 10) { msg.textContent = "Please enter a 10-digit phone number."; return; }

  if (!timeEl) { msg.textContent = "We're closed right now — call (541) 479-6532 to schedule ahead."; return; }

  if (SQUARE_CFG.appId.indexOf("REPLACE_") === 0) {

    msg.textContent = "Online card payment isn't switched on yet — call us and we'll take the order by phone.";

    return;

  }

  pickupInfo = { name, phone, time: timeEl.value };

  drawerStep = "pay"; renderDrawer();

}



function loadSquareSdk() {

  if (window.Square) return Promise.resolve();

  return new Promise((resolve, reject) => {

    const s = document.createElement("script");

    s.src = SQUARE_CFG.env === "production"

      ? "https://web.squarecdn.com/v1/square.js"

      : "https://sandbox.web.squarecdn.com/v1/square.js";

    s.onload = resolve; s.onerror = () => reject(new Error("Could not load payment form"));

    document.head.appendChild(s);

  });

}



async function renderPay() {

  const body = document.getElementById("drawerBody");

  const foot = document.getElementById("drawerFoot");

  document.getElementById("drawerTitle").textContent = "Payment";

  body.innerHTML =

    '<div style="padding-top:14px;">' +

      '<p style="font-size:14px;color:var(--ink-soft);">Picking up: <strong style="color:var(--ink)">' + pickupInfo.name + '</strong> · ' +

        (pickupInfo.time === "ASAP" ? "ASAP (about 15–20 min)" : pickupInfo.time) + '</p>' +

      '<div class="form-row" style="margin-top:14px;"><label>Card details</label><div id="card-container"></div></div>' +

      '<div class="pick-status bad" id="payMsg"></div>' +

      '<p class="fine" style="margin-top:10px;">Payments are processed securely by Square. Your card number never touches our site.</p>' +

    '</div>';

  foot.innerHTML =

    '<div class="subtotal-row"><span class="lbl">Total</span><span class="val">' + fmt(cartTotal()) + '</span></div>' +

    '<button class="btn btn-cinnabar" id="payBtn" disabled>Loading secure form…</button>' +

    '<p class="fine" style="margin-top:10px;"><button class="arrow-link" style="font-size:13px;" onclick="drawerStep=\'details\'; renderDrawer()">← Back to pickup details</button></p>';

  try {

    await loadSquareSdk();

    const payments = window.Square.payments(SQUARE_CFG.appId, SQUARE_CFG.locationId);

    sqCard = await payments.card();

    await sqCard.attach("#card-container");

    const btn = document.getElementById("payBtn");

    btn.disabled = false;

    btn.textContent = "Pay " + fmt(cartTotal());

    btn.onclick = paySubmit;

  } catch (e) {

    document.getElementById("payMsg").textContent = "Couldn't load the payment form. You can still call us: (541) 479-6532.";

  }

}



async function paySubmit() {

  const btn = document.getElementById("payBtn");

  const msg = document.getElementById("payMsg");

  btn.disabled = true; btn.textContent = "Processing…"; msg.textContent = "";

  try {

    const t = await sqCard.tokenize();

    if (t.status !== "OK") throw new Error((t.errors && t.errors[0] && t.errors[0].message) || "Card was not accepted.");

    const res = await fetch("/api/create-payment", {

      method: "POST",

      headers: { "Content-Type": "application/json" },

      body: JSON.stringify({

        token: t.token,

        cart: cart.map(l => ({ id: l.id, qty: l.qty, sel: l.sel, mods: l.mods })),

        customer: pickupInfo

      })

    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok || !data.ok) throw new Error(data.error || "Payment didn't go through.");

    window._receiptUrl = data.receiptUrl || "";

    cart = []; saveCart(); syncFab();

    drawerStep = "done"; renderDrawer();

  } catch (e) {

    msg.textContent = e.message + " No charge was completed — try again or call (541) 479-6532.";

    btn.disabled = false; btn.textContent = "Pay " + fmt(cartTotal());

  }

}



function renderDone() {

  document.getElementById("drawerTitle").textContent = "Order placed";

  document.getElementById("drawerBody").innerHTML =

    '<div style="padding-top:20px;">' +

      '<h3 style="font-size:1.5rem;">See you soon, ' + (pickupInfo.name || "") + '.</h3>' +

      '<p style="margin-top:10px; color:var(--ink-soft);">Your order is paid and headed to the kitchen. Pickup ' +

        (pickupInfo.time === "ASAP" ? "in about 15–20 minutes" : "at " + pickupInfo.time) + ' at 122 SE K St.</p>' +

      (window._receiptUrl ? '<p><a href="' + window._receiptUrl + '" target="_blank" rel="noopener">View your Square receipt →</a></p>' : '') +

    '</div>';

  document.getElementById("drawerFoot").innerHTML =

    '<button class="btn btn-solid" style="width:100%" onclick="closeCart(); drawerStep=\'cart\'">Done</button>';

}



/* ---------- Page navigation ---------- */

function showPage(name) {

  document.querySelectorAll('.page').forEach(function (p) { p.classList.remove('active'); });

  var target = document.getElementById('page-' + name);

  if (target) target.classList.add('active');

  document.querySelectorAll('nav.pages a').forEach(function (a) {

    a.classList.toggle('active', a.getAttribute('data-page') === name);

  });

  window.scrollTo({ top: 0 });

}

window.addEventListener('hashchange', function () {

  var name = location.hash.replace('#', '') || 'home';

  if (document.getElementById('page-' + name)) showPage(name);

});

if (location.hash) {

  var initial = location.hash.replace('#', '');

  if (document.getElementById('page-' + initial)) showPage(initial);

}



/* ---------- Open/closed status (Tue–Sat, noon–9, Pacific) ---------- */

function updateOpenStatus() {

  var el = document.getElementById('openStatus');

  var now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles' }));

  var day = now.getDay();

  var mins = now.getHours() * 60 + now.getMinutes();

  var OPEN = 12 * 60, CLOSE = 21 * 60;

  var openDays = [2, 3, 4, 5, 6];

  if (openDays.indexOf(day) !== -1 && mins >= OPEN && mins < CLOSE) {

    el.textContent = '● Open until 9:00 PM';

    el.className = 'status-open';

    return;

  }

  var d = day, daysAhead = 0;

  if (openDays.indexOf(day) !== -1 && mins < OPEN) { daysAhead = 0; }

  else { do { d = (d + 1) % 7; daysAhead++; } while (openDays.indexOf(d) === -1); }

  var names = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

  var when = daysAhead === 0 ? 'today' : (daysAhead === 1 ? 'tomorrow' : names[d]);

  el.textContent = '● Closed — opens ' + when + ' at 12:00 PM';

  el.className = 'status-closed';

}



/* ---------- Catering form ---------- */

function sendCateringRequest(e) {

  e.preventDefault();

  var body =

    'Catering request from the website:\n\n' +

    'Name: ' + document.getElementById('c-name').value + '\n' +

    'Phone: ' + document.getElementById('c-phone').value + '\n' +

    'Event date: ' + document.getElementById('c-date').value + '\n' +

    'Guests: ' + document.getElementById('c-guests').value + '\n' +

    'Occasion: ' + (document.getElementById('c-occasion').value || '—');

  // TODO before launch: replace with the restaurant's real email address

  location.href = 'mailto:REPLACE_WITH_RESTAURANT_EMAIL@example.com' +

    '?subject=' + encodeURIComponent('Catering Request — Four Seasons Restaurant') +

    '&body=' + encodeURIComponent(body);

  return false;

}



renderMenu();

applyOrderingMode();

updateOpenStatus();

setInterval(updateOpenStatus, 60000);

syncFab();

document.getElementById('year').textContent =

  new Date().toLocaleString('en-US', { timeZone: 'America/Los_Angeles', year: 'numeric' });

</script>

