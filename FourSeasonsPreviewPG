<style>
  :root {
    --navy: #1e3a5f;
    --navy-dark: #162c49;
    --gold: #c8912a;
    --gold-light: #e8b54d;
    --red: #b03a2e;
    --cream: #faf6ef;
    --white: #ffffff;
    --text: #2b2b2b;
    --text-light: #5a5a5a;
    --green: #2e7d32;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 19px;
    line-height: 1.65;
    color: var(--text);
    background: var(--cream);
  }
  h1, h2, h3 { font-family: Georgia, serif; color: var(--navy); line-height: 1.25; }
  h1 { font-size: 2.4rem; }
  h2 { font-size: 1.9rem; margin-bottom: 0.5em; }
  h3 { font-size: 1.35rem; margin-bottom: 0.4em; }
  p { margin-bottom: 1em; }
  a { color: var(--navy); }

  /* ---------- Buttons ---------- */
  .btn {
    display: inline-block;
    min-height: 52px;
    padding: 14px 28px;
    font-size: 1.15rem;
    font-weight: bold;
    font-family: Georgia, serif;
    text-decoration: none;
    text-align: center;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .btn-primary { background: var(--red); color: var(--white); }
  .btn-primary:hover { background: #93291e; }
  .btn-secondary { background: var(--white); color: var(--navy); border: 3px solid var(--navy); }
  .btn-secondary:hover { background: #eef2f7; }
  .btn-gold { background: var(--gold); color: var(--white); }
  .btn-gold:hover { background: #a97a1f; }
  .btn-row { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin: 1.2em 0; }

  /* ---------- Header ---------- */
  header {
    position: sticky; top: 0; z-index: 100;
    background: var(--white);
    border-bottom: 3px solid var(--gold);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  .header-inner {
    max-width: 1100px; margin: 0 auto; padding: 10px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;
  }
  .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
  .brand-mark {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--navy); color: var(--gold-light);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; flex-shrink: 0;
  }
  .brand-name { font-size: 1.35rem; font-weight: bold; color: var(--navy); line-height: 1.15; }
  .brand-sub { font-size: 0.85rem; color: var(--text-light); }
  .header-right { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .call-btn {
    background: var(--red); color: var(--white);
    padding: 12px 20px; border-radius: 8px;
    font-weight: bold; text-decoration: none; font-size: 1.1rem;
    min-height: 48px; display: inline-flex; align-items: center;
  }
  .open-status { font-size: 1rem; font-weight: bold; }
  .open-status.open { color: var(--green); }
  .open-status.closed { color: var(--red); }

  /* ---------- Nav ---------- */
  nav { background: var(--navy); }
  nav ul {
    max-width: 1100px; margin: 0 auto; padding: 0 8px;
    list-style: none; display: flex; flex-wrap: wrap; justify-content: center;
  }
  nav a {
    display: block; padding: 14px 18px;
    color: var(--white); text-decoration: none; font-size: 1.05rem;
  }
  nav a:hover, nav a.active { background: var(--navy-dark); color: var(--gold-light); }

  /* ---------- Page sections ---------- */
  .page { display: none; }
  .page.active { display: block; }
  section { padding: 48px 20px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .narrow { max-width: 760px; margin: 0 auto; }

  /* ---------- Hero ---------- */
  .hero {
    background: linear-gradient(rgba(22,44,73,0.72), rgba(22,44,73,0.72)),
      repeating-linear-gradient(45deg, #b03a2e 0, #b03a2e 20px, #a33227 20px, #a33227 40px);
    color: var(--white);
    text-align: center;
    padding: 80px 20px;
  }
  .hero h1 { color: var(--white); font-size: 2.7rem; margin-bottom: 0.4em; }
  .hero p { font-size: 1.3rem; max-width: 640px; margin: 0 auto 1.2em; }

  /* ---------- Trust strip ---------- */
  .trust-strip {
    background: var(--white); text-align: center;
    padding: 20px; font-size: 1.2rem;
    border-bottom: 1px solid #e5ddcf;
  }
  .stars { color: var(--gold); font-size: 1.4rem; letter-spacing: 3px; }

  /* ---------- Dish cards ---------- */
  .dish-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px; margin: 1.5em 0;
  }
  .dish-card {
    background: var(--white); border-radius: 10px; overflow: hidden;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08); text-align: center;
  }
  .dish-photo {
    height: 120px; display: flex; align-items: center; justify-content: center;
    font-size: 3rem; background: linear-gradient(135deg, #f6e7c9, #efd9a7);
  }
  .dish-card h3 { padding: 14px 10px; font-size: 1.15rem; color: var(--navy); }

  /* ---------- Catering band ---------- */
  .catering-band { background: var(--gold); color: var(--white); text-align: center; }
  .catering-band h2 { color: var(--white); }
  .catering-band p { font-size: 1.2rem; max-width: 680px; margin: 0 auto 1.2em; }
  .catering-band .btn-primary { background: var(--navy); }
  .catering-band .btn-primary:hover { background: var(--navy-dark); }

  /* ---------- Reviews ---------- */
  .quote-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin: 1.5em 0; }
  .quote {
    background: var(--white); border-left: 6px solid var(--gold);
    padding: 24px; border-radius: 8px; font-size: 1.2rem; font-style: italic;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }

  /* ---------- Visit / contact ---------- */
  .visit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  .map-frame { width: 100%; height: 320px; border: 0; border-radius: 10px; }
  .info-card { background: var(--white); border-radius: 10px; padding: 28px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
  .info-card p { font-size: 1.15rem; }
  .info-label { font-weight: bold; color: var(--navy); }

  /* ---------- Menu ---------- */
  .menu-cat {
    background: var(--white); border-radius: 10px; padding: 24px 28px;
    margin-bottom: 18px; box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .menu-cat h3 { border-bottom: 2px solid var(--gold); padding-bottom: 8px; }
  .menu-item {
    display: flex; justify-content: space-between; align-items: baseline; gap: 14px;
    padding: 8px 0; border-bottom: 1px dotted #d8d0c0; font-size: 1.08rem;
  }
  .menu-item:last-of-type { border-bottom: none; }
  .menu-item .price { white-space: nowrap; font-weight: bold; color: var(--navy); }
  .menu-item .desc { display: block; font-size: 0.92rem; color: var(--text-light); font-style: italic; }
  .menu-note { font-size: 0.98rem; color: var(--text-light); font-style: italic; margin: 8px 0 0; }
  .spice { color: var(--red); }

  /* ---------- Catering form ---------- */
  form { background: var(--white); border-radius: 10px; padding: 28px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
  .form-row { margin-bottom: 18px; }
  label { display: block; font-weight: bold; color: var(--navy); margin-bottom: 6px; font-size: 1.05rem; }
  input, select, textarea {
    width: 100%; padding: 14px; font-size: 1.1rem; font-family: Georgia, serif;
    border: 2px solid #c9c2b4; border-radius: 8px; min-height: 48px;
  }
  input:focus, select:focus, textarea:focus { outline: 3px solid var(--gold-light); border-color: var(--gold); }

  /* ---------- Footer ---------- */
  footer { background: var(--navy); color: #dce4ee; padding: 40px 20px; text-align: center; font-size: 1.05rem; }
  footer a { color: var(--gold-light); }
  footer .foot-phone { font-size: 1.4rem; font-weight: bold; }
  footer p { margin-bottom: 0.6em; }

  .center { text-align: center; }
  .section-alt { background: #f2ecdf; }

  @media (max-width: 720px) {
    body { font-size: 18px; }
    .hero h1 { font-size: 2rem; }
    .visit-grid { grid-template-columns: 1fr; }
    .header-inner { justify-content: center; text-align: center; }
    nav a { padding: 12px 12px; font-size: 1rem; }
  }
</style>
</head>
